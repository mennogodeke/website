<section class="cv-download-section">
  <h1 class="cv-download-title">Download CV</h1>
  <p class="cv-download-intro">Enter your email address and I'll send you a download link.</p>

  <% if notice %>
    <div class="notification is-success"><%= notice %></div>
  <% end %>
  <% if alert %>
    <div class="notification is-danger"><%= alert %></div>
  <% end %>

  <%= form_with model: @cv_download, url: cv_downloads_path, class: "cv-download-form" do |f| %>
    <div class="field">
      <%= f.label :email, class: "label" %>
      <div class="control">
        <%= f.email_field :email, class: "input #{'is-danger' if @cv_download.errors[:email].any?}", placeholder: "you@example.com", autofocus: true %>
      </div>
      <% @cv_download.errors[:email].each do |message| %>
        <p class="help is-danger"><%= message %></p>
      <% end %>
    </div>

    <div class="cv-download-actions">
      <%= f.submit "Send download link", class: "button is-dark" %>
      <span class="cv-download-or">or</span>
      <%= link_to "See in browser", cv_path, class: "button" %>
    </div>
  <% end %>
</section>
