<div class="box">
  <div class="level">
    <div class="level-left">
      <h3 class="title is-3"><%= job.title %></h3>
      <h6 class="subtitle is-6"><%= job.company %></h6>
    </div>
    <div class="level-right">
      <span class="tag">
        <%= job.start_date.strftime("%b %Y") %> – <%= job_end_date(job.end_date) %>
      </span>
    </div>
  </div>
  <p><%= job.description %></p>
</div>
