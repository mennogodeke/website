<% initials = job.company.first.upcase %>
<div class="tl-entry<%= " is-open" if first %>"
     style="--entry-accent: var(--color-text)"
     data-controller="career-entry"
     data-career-target="entry">

  <div class="tl-header" data-action="click->career-entry#toggle">
    <div class="tl-company-logo"><%= initials %></div>
    <div class="tl-header-main">
      <div class="tl-role-row">
        <div class="tl-role"><span class="highlight-primary"><%= job.title %></span></div>
        <span class="tl-at-company">@ <%= job.company %></span>
      </div>
    </div>
    <div class="tl-chevron"><i class="fa-solid fa-chevron-down" aria-hidden="true"></i></div>
  </div>

  <div class="tl-body">
    <div class="tl-body-inner">
      <div class="tl-body-content">
        <p class="tl-desc"><%= job.description.strip %></p>
        <% if job.skills.any? %>
          <div class="tl-skills">
            <% job.skills.each do |skill| %>
              <span class="skill-tag" style="--chip-c: <%= skill.accent %>" data-tip="<%= skill.description.strip %>">
                <i class="<%= skill.icon %>"></i><%= skill.name %>
              </span>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="tl-rail" aria-hidden="true">
    <span class="yr"><%= job.end_date ? job.end_date.year : "NOW" %></span>
    <div class="tl-rail-dot"></div>
    <span class="yr"><%= job.start_date.year %></span>
  </div>
</div>
