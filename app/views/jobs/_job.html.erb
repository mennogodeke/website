<% initials = job.company.split.map { |w| w[0] }.join.upcase.first(2) %>
<% rarity_class = highlight_class.sub("highlight-", "tl-entry--") %>
<div class="tl-entry <%= rarity_class %>" data-controller="career-entry" data-career-target="entry">
  <div class="tl-dot"></div>
  <div class="tl-header" data-action="click->career-entry#toggle">
    <div class="tl-logo"><%= initials %></div>
    <div class="tl-header-main">
      <div class="tl-role">
        <span class="<%= highlight_class %>"><%= job.title %></span><span class="tl-company"> @ <%= job.company %></span>
      </div>
      <div class="tl-meta tl-dates"><%= job.start_date.strftime("%b %Y").upcase %> · <%= job.end_date ? job.end_date.strftime("%b %Y").upcase : "Present" %></div>
    </div>
    <div class="tl-header-right">
      <div class="tl-chevron"><i class="fa-solid fa-chevron-down"></i></div>
    </div>
  </div>
  <div class="tl-body">
    <div class="tl-body-inner">
      <div class="tl-body-content">
        <p class="tl-desc"><%= job.description.strip %></p>
        <% if job.skills.any? %>
          <div class="tl-skills">
            <% job.skills.each do |skill| %>
              <% chip_color = skill.accent.present? ? skill.accent : "var(--color-text-faint)" %>
              <span class="skill-tag" style="--chip-c: <%= chip_color %>" data-tip="<%= skill.description.strip %>">
                <i class="<%= skill.icon %>"></i><%= skill.name %>
              </span>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
