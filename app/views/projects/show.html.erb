<section class="section container">

  <div class="mb-5">
    <h1><%= @project.name %></h1>
  </div>

  <div class="img-stub proj-hero mb-6">
    <span class="text-xs"><%= @project.name %> hero shot</span>
  </div>

  <div class="proj-detail-row">

    <aside class="proj-detail-meta">
      <div class="proj-meta-row">
        <p class="text-xs text-faint">Year</p>
        <p><%= @project.year %></p>
      </div>
      <div class="proj-meta-row">
        <p class="text-xs text-faint">Stack</p>
        <div class="tags mt-1">
          <% @project.skills.each do |skill| %>
            <span class="tag"><%= skill.name %></span>
          <% end %>
        </div>
      </div>
      <div class="proj-meta-row">
        <p class="text-xs text-faint mb-2">Links</p>
        <div class="proj-links">
          <% if @project.url.present? %>
            <%= link_to "↗ #{@project.url}", safe_url(@project.url), class: "text-xs", target: "_blank", rel: "noopener" %>
          <% end %>
          <% if @project.repo_url.present? %>
            <%= link_to "↗ repo", safe_url(@project.repo_url), class: "text-xs", target: "_blank", rel: "noopener" %>
          <% end %>
          <% if @project.url.blank? && @project.repo_url.blank? %>
            <span class="text-xs">No public links</span>
          <% end %>
        </div>
      </div>
    </aside>

    <div class="proj-detail-content">
      <p class="text-md mb-6"><%= @project.description %></p>
      <div class="proj-actions">
        <% if @project.url.present? %>
          <%= link_to "↗ Live", safe_url(@project.url), class: "btn btn-primary", target: "_blank", rel: "noopener" %>
        <% end %>
        <% if @project.repo_url.present? %>
          <%= link_to "↗ Repo", safe_url(@project.repo_url), class: "btn btn-secondary", target: "_blank", rel: "noopener" %>
        <% end %>
      </div>
    </div>

  </div>
</section>
