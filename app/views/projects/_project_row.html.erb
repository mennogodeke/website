<a href="<%= project_path(project) %>" class="proj-row <%= index.odd? ? 'flipped' : '' %>">
  <div class="proj-content">
    <p class="text-xs mb-2"><%= project.year %></p>
    <h3 class="mb-2"><%= project.name %></h3>
    <p class="mb-4"><%= project.description %></p>
    <div class="tags mb-4">
      <% project.skills.each do |skill| %>
        <span class="tag"><%= skill.name %></span>
      <% end %>
    </div>
    <div class="proj-cta-row">
      <span class="proj-cta">View case study →</span>
      <% if project.url.present? %>
        <span class="text-xs">↗ <%= project.url %></span>
      <% end %>
      <% if project.repo_url.present? %>
        <span class="text-xs">↗ repo</span>
      <% end %>
    </div>
  </div>
  <div class="proj-img img-stub">
    <span class="text-xs"><%= project.name %> screenshot</span>
  </div>
</a>
