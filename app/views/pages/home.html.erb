<%# ============================================================ %>
<%# HERO %>
<%# ============================================================ %>
<section class="home-hero">
  <div class="hero-inner">

    <div class="hero-left">
      <div class="hero-badge">LVL 30 &middot; ENGINEER</div>

      <h1 class="title is-1 hero-name">MENNO<br>GODEKE</h1>

      <p class="hero-bio">
        Senior backend engineer who builds <strong>Ruby on Rails</strong>
        systems that don't fall over. 10 years of XP, 30+ shipped
        projects, and a soft spot for well-named variables.
      </p>

      <div class="hero-ctas">
        <%= link_to projects_path, class: "button is-primary" do %>
          VIEW WORK <i class="fa-solid fa-arrow-right"></i>
        <% end %>
        <%= link_to new_cv_download_path, class: "button is-outlined" do %>
          DOWNLOAD CV
        <% end %>
      </div>

      <div class="hero-status">
        <span class="status-dot"></span>
        <span class="status-label">OPEN FOR COLLABS &middot; AMSTERDAM, NL</span>
      </div>
    </div>

    <div class="hero-right">
      <figure class="image is-384x384 hero-avatar">
        <img class="is-rounded" src="https://placehold.co/384x384/000000/333333" alt="Menno Godeke">
      </figure>
    </div>

  </div>
</section>


