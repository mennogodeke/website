<%# ── Hero ── %>
<div class="home-hero container section">
  <div class="chip-field">
    <span class="floating-chip floating-chip--orange" style="--cx:5%;--cy:12%"><i class="devicon-ruby-plain"></i></span>
    <span class="floating-chip floating-chip--orange" style="--cx:88%;--cy:8%"><i class="devicon-rails-plain"></i></span>
    <span class="floating-chip floating-chip--orange" style="--cx:72%;--cy:72%"><i class="devicon-redis-plain"></i></span>
    <span class="floating-chip floating-chip--orange" style="--cx:18%;--cy:82%"><i class="devicon-swift-plain"></i></span>
    <span class="floating-chip floating-chip--blue"   style="--cx:92%;--cy:38%"><i class="devicon-go-original-wordmark"></i></span>
    <span class="floating-chip floating-chip--blue"   style="--cx:3%;--cy:55%"><i class="devicon-docker-plain"></i></span>
    <span class="floating-chip floating-chip--blue"   style="--cx:55%;--cy:88%"><i class="devicon-terraform-plain"></i></span>
    <span class="floating-chip floating-chip--blue"   style="--cx:80%;--cy:22%"><i class="devicon-amazonwebservices-plain-wordmark"></i></span>
    <span class="floating-chip floating-chip--blue"   style="--cx:40%;--cy:5%"><i class="devicon-kubernetes-plain"></i></span>
    <span class="floating-chip floating-chip--blue"   style="--cx:65%;--cy:55%"><i class="devicon-grafana-original"></i></span>
    <span class="floating-chip floating-chip--purple" style="--cx:25%;--cy:35%"><i class="devicon-postgresql-plain"></i></span>
    <span class="floating-chip floating-chip--green"  style="--cx:10%;--cy:68%"><i class="devicon-vuejs-plain"></i></span>
    <span class="floating-chip floating-chip--green"  style="--cx:48%;--cy:78%"><i class="devicon-typescript-plain"></i></span>
    <span class="floating-chip floating-chip--green"  style="--cx:82%;--cy:88%"><i class="devicon-nodejs-plain"></i></span>
    <span class="floating-chip floating-chip--yellow" style="--cx:32%;--cy:18%"><i class="devicon-linux-plain"></i></span>
    <span class="floating-chip floating-chip--yellow" style="--cx:92%;--cy:62%"><i class="devicon-python-plain"></i></span>
  </div>

  <div class="home-hero-grid">

    <%# Left: site identity %>
    <div>
      <p class="text-xs text-primary mb-3">Hi, I'm Menno</p>
      <p class="subtitle mb-1">Welcome to</p>
      <h1 class="home-site-title mb-5"><span class="text-primary">MENNO</span>.CODES</h1>
      <p class="home-hero-sub">My little corner of the internet — a personal portfolio and interactive CV where you can explore my work, browse my experience, and grab my CV if you like what you see.</p>
    </div>

    <%# Right: personal intro %>
    <div class="home-hero-right">

      <div class="home-headshot img-stub">
        <span class="text-xs">headshot</span>
      </div>

      <div>
        <h4 class="mb-2">Fullstack Software Engineer</h4>
        <span class="home-badge"><span class="home-badge-dot"></span>Open to work</span>
      </div>

      <p class="home-hero-bio">10 years building back-end systems, full-stack web apps, and developer tooling. Ruby on Rails at the core. Everything else as needed.</p>

      <div class="home-hero-actions">
        <%= link_to "Get My CV →", new_cv_download_path, class: "btn btn-primary" %>
        <%= link_to "Get in Touch", contact_path, class: "btn btn-secondary" %>
      </div>

    </div>
  </div>
</div>

<%# ── Footer CTA ── %>
<div class="home-footer-cta container">
  <h2>Open to work.<br><span class="text-primary">Let's talk.</span></h2>
  <div class="home-hero-actions">
    <%= link_to "Get My CV →", new_cv_download_path, class: "btn btn-primary" %>
    <%= link_to "Get in Touch", contact_path, class: "btn btn-secondary" %>
  </div>
</div>
