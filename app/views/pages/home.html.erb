<%# ============================================================ %>
<%# HERO %>
<%# ============================================================ %>
<section class="home-hero">
  <div class="hero-inner">

    <div class="hero-left">
      <div class="hero-badge">LVL 30 &middot; ENGINEER</div>

      <h1 class="hero-name">MENNO<br>GODEKE</h1>

      <p class="hero-bio">
        Senior backend engineer who builds <strong>Ruby on Rails</strong>
        systems that don't fall over. 10 years of XP, 30+ shipped
        projects, and a soft spot for well-named variables.
      </p>

      <div class="hero-ctas">
        <%= link_to projects_path, class: "btn-primary" do %>
          VIEW WORK <i class="fa-solid fa-arrow-right"></i>
        <% end %>
        <%= link_to new_cv_download_path, class: "btn-outline" do %>
          DOWNLOAD CV
        <% end %>
      </div>

      <div class="hero-status">
        <span class="status-dot"></span>
        <span class="status-label">OPEN FOR COLLABS &middot; AMSTERDAM, NL</span>
      </div>
    </div>

    <div class="hero-right">
      <div class="hex-glow">
        <div class="hex-border">
          <div class="hex-inner">
            <i class="fa-solid fa-user"></i>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>

<%# ============================================================ %>
<%# STATS %>
<%# ============================================================ %>
<section class="home-stats">
  <div class="stats-inner">
    <div class="stat-item">
      <span class="stat-number">10+</span>
      <span class="stat-label">Years back-end</span>
    </div>
    <div class="stat-divider"></div>
    <div class="stat-item">
      <span class="stat-number">6+</span>
      <span class="stat-label">Years cloud & DevOps</span>
    </div>
    <div class="stat-divider"></div>
    <div class="stat-item">
      <span class="stat-number">30+</span>
      <span class="stat-label">Projects shipped</span>
    </div>
    <div class="stat-divider"></div>
    <div class="stat-item">
      <span class="stat-number">4+</span>
      <span class="stat-label">Years iOS & macOS</span>
    </div>
  </div>
</section>

