<%# ============================================================ %>
<%# 1. HERO — who I am %>
<%# ============================================================ %>
<section class="home-hero">
  <p class="home-eyebrow"><%= t '.hello' %></p>
  <h1 class="home-title"><%= t '.title' %></h1>
  <p class="home-tagline">
    <%= t '.subtitle' %>
  </p>
  <div class="home-hero-ctas">
    <a href="#" class="button"><%= t '.cv_cta' %></a>
    <a href="#" class="button"><%= t '.contact_cta' %></a>
  </div>
</section>

<%# ============================================================ %>
<%# 2. WHAT I DO — expertise stat level %>
<%# ============================================================ %>
<section class="home-section home-what-i-do">
  <nav class="level">
    <div class="level-item has-text-centered">
      <div>
        <p class="title">8+</p>
        <p class="heading">Years back-end</p>
      </div>
    </div>
    <div class="level-item has-text-centered">
      <div>
        <p class="title">6+</p>
        <p class="heading">Years cloud & DevOps</p>
      </div>
    </div>
    <div class="level-item has-text-centered">
      <div>
        <p class="title">4+</p>
        <p class="heading">Years iOS & macOS</p>
      </div>
    </div>
    <div class="level-item has-text-centered">
      <div>
        <p class="title">3+</p>
        <p class="heading">Years front-end</p>
      </div>
    </div>
  </nav>
</section>

<%# ============================================================ %>
<%# 3. WHAT I'VE BUILT — projects teaser %>
<%# ============================================================ %>
<section class="home-section home-projects">
  <div class="home-section-label">What I've built</div>
  <div class="home-section-body">
    <p class="home-section-intro">
      A selection of things I've shipped, broken, and fixed again.
    </p>
    <div class="projects-placeholder">Projects coming soon.</div>
    <a href="#" class="home-section-link">See all projects →</a>
  </div>
</section>

<%# ============================================================ %>
<%# 4. WHERE I'VE WORKED — career teaser %>
<%# ============================================================ %>
<section class="home-section home-career">
  <div class="home-section-label">Where I've worked</div>
  <div class="home-section-body">
    <p class="home-section-intro">
      From intern to senior engineer — a few of the places I've called home.
    </p>
    <ol class="career-teaser-list">
      <li>
        <span class="career-role">Senior Software Engineer</span>
        <span class="career-company">Kape Technologies</span>
        <span class="career-dates">Feb 2022 – Jan 2026</span>
      </li>
      <li>
        <span class="career-role">Software Engineer</span>
        <span class="career-company">Kape Technologies</span>
        <span class="career-dates">Feb 2019 – Jan 2022</span>
      </li>
      <li>
        <span class="career-role">Junior Software Engineer</span>
        <span class="career-company">ZenGuard</span>
        <span class="career-dates">Aug 2017 – Jan 2019</span>
      </li>
    </ol>
    <a href="#" class="home-section-link">See full timeline →</a>
  </div>
</section>

<%# ============================================================ %>
<%# 5. CTA — let's work together %>
<%# ============================================================ %>
<section class="home-cta">
  <h2>Want to work together?</h2>
  <p>I'm available for freelance work. Let's talk.</p>
  <div class="home-cta-buttons">
    <a href="#" class="button">Get in touch</a>
    <a href="#" class="button">Download CV</a>
  </div>
</section>
