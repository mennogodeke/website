<section class="section container">
  <p class="subtitle mb-2"><%= t("contact.subtitle") %></p>
  <h1 class="mb-4"><%= t("contact.title") %></h1>
  <p class="contact-intro"><%= t("contact.intro") %></p>

  <div class="contact-layout">
    <div class="contact-form-wrapper">
      <%= form_with url: "#", method: :post, class: "contact-form" do |f| %>
        <div class="field">
          <%= f.label :name, t("contact.form.name"), class: "label" %>
          <div class="control">
            <%= f.text_field :name, class: "input", placeholder: t("contact.form.name_placeholder") %>
          </div>
        </div>

        <div class="field">
          <%= f.label :email, t("contact.form.email"), class: "label" %>
          <div class="control">
            <%= f.email_field :email, class: "input", placeholder: "your@email.com" %>
          </div>
        </div>

        <div class="field">
          <%= f.label :message, t("contact.form.message"), class: "label" %>
          <div class="control">
            <%= f.text_area :message, class: "textarea", placeholder: t("contact.form.message_placeholder"), rows: 6 %>
          </div>
        </div>

        <div class="field">
          <div class="control">
            <%= f.submit t("contact.form.submit"), class: "btn btn-primary" %>
          </div>
        </div>
      <% end %>
    </div>

    <div class="social-icons">
      <a href="https://github.com/mennogodeke" class="social-icon" aria-label="GitHub" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-github" aria-hidden="true"></i></a>
      <a href="https://www.linkedin.com/in/menno-godeke-b5b09b10a/" class="social-icon" aria-label="LinkedIn" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-linkedin-in" aria-hidden="true"></i></a>
      <a href="https://discord.com/users/1510284386296401932" class="social-icon" aria-label="Discord" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-discord" aria-hidden="true"></i></a>
      <a href="https://mennocodes.slack.com" class="social-icon" aria-label="Slack" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-slack" aria-hidden="true"></i></a>
      <a href="mailto:info@menno.codes" class="social-icon" aria-label="Email"><i class="fa-solid fa-envelope" aria-hidden="true"></i></a>
    </div>
  </div>
</section>
