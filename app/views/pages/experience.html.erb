<%# ============================================================ %>
<%# 1. EXPERTISE — feature cards grid %>
<%# ============================================================ %>
<section class="experience-section">
  <h1 class="experience-title">Experience</h1>

  <div class="expertise-grid">
    <% @expertises.each_with_index do |expertise, index| %>
      <div class="expertise-card <%= 'is-featured' if index.zero? %>">
        <span class="expertise-card-years"><%= expertise.years_of_experience %>+</span>
        <h2 class="expertise-card-name"><%= expertise.name %></h2>
        <p class="expertise-card-description"><%= expertise.description %></p>
        <div class="expertise-card-tags">
          <% expertise.skills.each do |skill| %>
            <span class="tag"><%= skill.name %></span>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</section>

<%# ============================================================ %>
<%# 2. SKILLS — smart grid, sized by proficiency (1–3) %>
<%# ============================================================ %>
<section class="experience-section skills-section">
  <h2 class="experience-subtitle">Skills</h2>
  <p>Coming soon.</p>
</section>
