<%# ============================================================ %>
<%# Design Preview — living reference for the design system %>
<%# ============================================================ %>

<section class="section">
  <div class="container is-max-widescreen">
    <h1 class="title is-1">Design Preview</h1>
  </div>
</section>

<%# ============================================================ %>
<%# 1. TYPOGRAPHY %>
<%# ============================================================ %>
<section class="section">
  <div class="container is-max-widescreen">
    <h2 class="title is-2">Typography</h2>

    <h3 class="title is-3">Titles</h3>
    <div class="mb-6">
      <h1 class="title is-1">Title is-1 — The quick brown fox</h1>
      <h2 class="title is-2">Title is-2 — The quick brown fox</h2>
      <h3 class="title is-3">Title is-3 — The quick brown fox</h3>
      <h4 class="title is-4">Title is-4 — The quick brown fox</h4>
      <h5 class="title is-5">Title is-5 — The quick brown fox</h5>
      <h6 class="title is-6">Title is-6 — The quick brown fox</h6>
    </div>

    <h3 class="title is-3">Subtitles</h3>
    <div class="mb-6">
      <h1 class="subtitle is-1">Subtitle is-1 — The quick brown fox</h1>
      <h2 class="subtitle is-2">Subtitle is-2 — The quick brown fox</h2>
      <h3 class="subtitle is-3">Subtitle is-3 — The quick brown fox</h3>
      <h4 class="subtitle is-4">Subtitle is-4 — The quick brown fox</h4>
      <h5 class="subtitle is-5">Subtitle is-5 — The quick brown fox</h5>
      <h6 class="subtitle is-6">Subtitle is-6 — The quick brown fox</h6>
    </div>

    <h3 class="title is-3">Title + Subtitle pairing</h3>
    <div>
      <h1 class="title is-1">Title is-1</h1>
      <h2 class="subtitle is-3">Subtitle is-3 paired below</h2>
    </div>
    <div>
      <h3 class="title is-3">Title is-3</h3>
      <h4 class="subtitle is-5">Subtitle is-5 paired below</h4>
    </div>
  </div>
</section>

<%# ============================================================ %>
<%# 2. COLORS %>
<%# ============================================================ %>
<section class="section">
  <div class="container is-max-widescreen">
    <h2 class="title is-2">Colors</h2>

    <h3 class="title is-3">Theme colors</h3>
    <div class="columns is-multiline mb-6">
      <% [
        { name: "primary", label: "Primary" },
        { name: "link",    label: "Link" },
        { name: "info",    label: "Info" },
        { name: "success", label: "Success" },
        { name: "warning", label: "Warning" },
        { name: "danger",  label: "Danger" },
      ].each do |color| %>
        <div class="column is-narrow">
          <div class="has-background-<%= color[:name] %>" style="width:120px; height:80px; margin-bottom:.5rem;"></div>
          <p class="is-size-7 has-text-weight-semibold"><%= color[:label] %></p>
          <p class="is-size-7 has-text-grey">has-background-<%= color[:name] %></p>
        </div>
      <% end %>
    </div>

    <h3 class="title is-3">Neutral colors</h3>
    <div class="columns is-multiline mb-6">
      <% [
        { name: "white",      label: "White",      border: true },
        { name: "light",      label: "Light",      border: false },
        { name: "dark",       label: "Dark",       border: false },
        { name: "black",      label: "Black",      border: false },
      ].each do |color| %>
        <div class="column is-narrow">
          <div class="has-background-<%= color[:name] %><%= " box" if color[:border] %>" style="width:120px; height:80px; margin-bottom:.5rem; <%= "border: 1px solid #dbdbdb;" if color[:border] %>"></div>
          <p class="is-size-7 has-text-weight-semibold"><%= color[:label] %></p>
          <p class="is-size-7 has-text-grey">has-background-<%= color[:name] %></p>
        </div>
      <% end %>
    </div>

    <h3 class="title is-3">Text colors</h3>
    <div class="columns is-multiline">
      <% ["primary", "link", "info", "success", "warning", "danger", "dark", "grey", "grey-light", "grey-dark"].each do |color| %>
        <div class="column is-narrow">
          <p class="has-text-<%= color %> has-text-weight-semibold"><%= color.capitalize %></p>
          <p class="is-size-7 has-text-grey">has-text-<%= color %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%# ============================================================ %>
<%# 3. BUTTONS %>
<%# ============================================================ %>
<section class="section">
  <div class="container is-max-widescreen">
    <h2 class="title is-2">Buttons</h2>

    <h3 class="title is-3">Colors</h3>
    <div class="buttons mb-6">
      <a class="button">Default</a>
      <a class="button is-white">White</a>
      <a class="button is-light">Light</a>
      <a class="button is-dark">Dark</a>
      <a class="button is-black">Black</a>
      <a class="button is-text">Text</a>
      <a class="button is-ghost">Ghost</a>
      <a class="button is-primary">Primary</a>
      <a class="button is-link">Link</a>
      <a class="button is-info">Info</a>
      <a class="button is-success">Success</a>
      <a class="button is-warning">Warning</a>
      <a class="button is-danger">Danger</a>
    </div>

    <h3 class="title is-3">Outlined</h3>
    <div class="buttons mb-6">
      <a class="button is-primary is-outlined">Primary</a>
      <a class="button is-link is-outlined">Link</a>
      <a class="button is-info is-outlined">Info</a>
      <a class="button is-success is-outlined">Success</a>
      <a class="button is-warning is-outlined">Warning</a>
      <a class="button is-danger is-outlined">Danger</a>
    </div>

    <h3 class="title is-3">Rounded</h3>
    <div class="buttons mb-6">
      <a class="button is-rounded">Default</a>
      <a class="button is-primary is-rounded">Primary</a>
      <a class="button is-link is-rounded">Link</a>
      <a class="button is-info is-rounded">Info</a>
      <a class="button is-success is-rounded">Success</a>
      <a class="button is-warning is-rounded">Warning</a>
      <a class="button is-danger is-rounded">Danger</a>
    </div>

    <h3 class="title is-3">Sizes</h3>
    <div class="buttons is-vcentered mb-6">
      <a class="button is-small">Small</a>
      <a class="button">Normal</a>
      <a class="button is-medium">Medium</a>
      <a class="button is-large">Large</a>
    </div>

    <h3 class="title is-3">States</h3>
    <div class="buttons mb-6">
      <a class="button is-primary">Normal</a>
      <a class="button is-primary is-hovered">Hovered</a>
      <a class="button is-primary is-focused">Focused</a>
      <a class="button is-primary is-active">Active</a>
      <a class="button is-primary is-loading">Loading</a>
      <a class="button is-primary" disabled>Disabled</a>
    </div>

    <h3 class="title is-3">With icons</h3>
    <div class="buttons mb-6">
      <a class="button is-primary">
        <span>View Work</span>
        <span class="icon"><i class="fa-solid fa-arrow-right"></i></span>
      </a>
      <a class="button is-outlined">
        <span class="icon"><i class="fa-solid fa-download"></i></span>
        <span>Download CV</span>
      </a>
      <a class="button">
        <span class="icon"><i class="fa-brands fa-github"></i></span>
      </a>
    </div>
  </div>
</section>
