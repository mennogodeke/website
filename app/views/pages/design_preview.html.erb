<%# ============================================================ %>
<%# DESIGN PREVIEW — component showcase for the design system   %>
<%# ============================================================ %>

<section class="section container">
  <h1 class="mb-6">Design Preview</h1>

  <%# ── Colors ── %>
  <h2 class="mb-4">Colors</h2>
  <div class="dp-color-grid mb-6">
    <% {
      "Primary"   => "var(--color-primary)",
      "Legendary" => "var(--color-legendary)",
      "Epic"      => "var(--color-epic)",
      "Rare"      => "var(--color-rare)",
      "Uncommon"  => "var(--color-uncommon)",
      "Common"    => "var(--color-common)",
    }.each do |name, value| %>
      <div class="dp-swatch" style="background:<%= value %>">
        <span class="text-xs"><%= name %></span>
      </div>
    <% end %>
    <% {
      "BG"      => "var(--color-bg)",
      "BG-2"    => "var(--color-bg-2)",
      "BG-Card" => "var(--color-bg-card)",
      "Border"  => "var(--color-border-2)",
    }.each do |name, value| %>
      <div class="dp-swatch dp-swatch-dark" style="background:<%= value %>">
        <span class="text-xs"><%= name %></span>
      </div>
    <% end %>
  </div>

  <%# ── Typography ── %>
  <h2>Typography</h2>
  <h1>H1 Title Anton H1</h1>
  <h2><span class="highlight-rare">H2 Heading Anton SC H2</span></h2>
  <h3><span class="highlight-epic">H3 Heading Anton SC H3</span></h3>
  <h4><span class="highlight-uncommon">H4 Heading Anton SC H4</span></h4>
  <h5>H5 Heading Anton SC H5</h5>
  <h6>H6 Heading Anton SC H6</h6>

  <h1><span class="highlight-primary">Zines cold plunge tote bag</span></h1>
  <h2><span class="highlight-legendary">Hoodie taxidermy single-origin coffee</span></h2>
  <h3><span class="highlight-epic">Artisan fixie kombucha small batch</span></h3>
  <h4><span class="highlight-rare">Vibe coded straight-to-podcast</span></h4>
  <h5><span class="highlight-uncommon">Thrifted nduja solarpunk shaman</span></h5>
  <h6><span class="highlight-common">Mullet small batch kale chips raclette</span></h6>
  <p>Iykyk twee disrupt, issey miyake organic yo la tengo freire chia pinterest needle felting birkenstocks cassavetes. Gawker jawn new balance four loko letterboxd ascot. Cliche nepo baby DIY, manifesting in this economy offill cardigan mezcal car seat headrest nervous system super 8 schlitz keffiyeh. Bluesky meh bitters helvetica, mushroom coffee roaster flannel selvage ketamine therapy tinned fish dream pop solarpunk black trumpet. Kickstarter wide-leg stussy forage caviar bump. Mullet small batch thrifted nduja, kale chips raclette chicharrones ramps issey miyake meh subway tile solarpunk shaman.</p>
  <div class="mb-6">
    <h3 class="mb-3">Body text</h3>
    <p class="mb-2">Default paragraph — The quick brown fox jumps over the lazy dog.</p>
    <p class="text-sm mb-2">text-sm — The quick brown fox jumps over the lazy dog.</p>
    <p class="text-xs mb-2">text-xs — The quick brown fox jumps over the lazy dog.</p>
    <p class="text-xs">text-xs — 8yr Back-End · 5yr DevOps · 3yr Cloud</p>
  </div>

  <div class="mb-6">
    <h3 class="mb-3">Font weights</h3>
    <p class="font-light mb-2">font-light (300) — The quick brown fox jumps over the lazy dog.</p>
    <p class="font-regular mb-2">font-regular (400) — The quick brown fox jumps over the lazy dog.</p>
    <p class="font-medium mb-2">font-medium (500) — The quick brown fox jumps over the lazy dog.</p>
    <p class="font-semibold mb-2">font-semibold (600) — The quick brown fox jumps over the lazy dog.</p>
    <p class="font-bold mb-2">font-bold (700) — The quick brown fox jumps over the lazy dog.</p>
    <p class="font-extrabold mb-2">font-extrabold (800) — The quick brown fox jumps over the lazy dog.</p>
    <p class="font-black">font-black (900) — The quick brown fox jumps over the lazy dog.</p>
  </div>

  <%# ── Buttons ── %>
  <h2 class="mb-4">Buttons</h2>

  <h3 class="mb-3">Variants</h3>
  <div class="dp-btn-group mb-4">
    <a class="btn">Default</a>
    <a class="btn btn-primary">Primary</a>
    <a class="btn btn-secondary">Secondary</a>
  </div>

  <h3 class="mb-3">Sizes</h3>
  <div class="dp-btn-group mb-4">
    <a class="btn btn-primary btn-sm">Small</a>
    <a class="btn btn-primary">Normal</a>
    <a class="btn btn-primary btn-lg">Large</a>
  </div>

  <h3 class="mb-3">States</h3>
  <div class="dp-btn-group mb-6">
    <a class="btn btn-primary">Normal</a>
    <a class="btn btn-primary is-loading">Loading</a>
    <a class="btn btn-primary" disabled>Disabled</a>
    <a class="btn btn-secondary">Secondary</a>
    <a class="btn btn-secondary" disabled>Secondary Disabled</a>
  </div>

  <%# ── Notifications ── %>
  <h2 class="mb-4">Notifications</h2>
  <div class="mb-6">
    <div class="notification notification-success">Your CV link has been sent — check your inbox.</div>
    <div class="notification notification-danger">That email address doesn't look right. Please try again.</div>
  </div>

  <%# ── Skill chips ── %>
  <h2 class="mb-4">Skill Chips</h2>
  <div class="dp-chip-row mb-6">
    <% [
      { icon: "devicon-ruby-plain",           accent: "#CC342D", name: "Ruby"       },
      { icon: "devicon-rails-plain",          accent: "#CC0000", name: "Rails"      },
      { icon: "devicon-docker-plain",         accent: "#2496ED", name: "Docker"     },
      { icon: "devicon-javascript-plain",     accent: "#F7DF1E", name: "JavaScript" },
      { icon: "devicon-go-plain",             accent: "#00ADD8", name: "Go"         },
      { icon: "devicon-kubernetes-plain",     accent: "#326CE5", name: "Kubernetes" },
      { icon: "devicon-swift-plain",          accent: "#F05138", name: "Swift"      },
      { icon: "devicon-postgresql-plain",     accent: "#336791", name: "PostgreSQL" },
    ].each do |chip| %>
      <div class="dp-chip-wrap">
        <div class="dp-skill-chip" style="--chip-c: <%= chip[:accent] %>" data-tip="<%= chip[:name] %>">
          <i class="<%= chip[:icon] %>"></i>
        </div>
      </div>
    <% end %>
  </div>

  <%# ── Skill tags ── %>
  <h2 class="mb-4">Skill Tags</h2>
  <div class="tags mb-6">
    <% [
      { icon: "devicon-ruby-plain",                        accent: "#CC342D", name: "Ruby",        tip: "The language behind the Rails magic — clean, expressive, and still a joy to write."              },
      { icon: "devicon-rails-plain",                       accent: "#CC0000", name: "Rails",       tip: "Primary back-end framework — APIs, payment integrations, and full-stack web applications."       },
      { icon: "devicon-javascript-plain",                  accent: "#F7DF1E", name: "JavaScript",  tip: "Front-end scripting alongside back-end Rails projects — from vanilla JS to component-based work." },
      { icon: "devicon-go-plain",                          accent: "#00ADD8", name: "Go",          tip: "Systems programming and microservices — fast, explicit, and refreshingly boring."                 },
      { icon: "devicon-docker-plain",                      accent: "#2496ED", name: "Docker",      tip: "Containerising apps for consistent local development and reliable production deployments."        },
      { icon: "devicon-kubernetes-plain",                  accent: "#326CE5", name: "Kubernetes",  tip: "Container orchestration for production workloads — deployments, scaling, and the odd YAML."      },
      { icon: "devicon-swift-plain",                       accent: "#F05138", name: "Swift",       tip: "Native app development for iOS and macOS, plus server-side Swift with Vapor."                    },
      { icon: "devicon-postgresql-plain",                  accent: "#336791", name: "PostgreSQL",  tip: "Go-to relational database for production Rails apps — rock solid and well understood."           },
      { icon: "devicon-amazonwebservices-plain-wordmark",  accent: "#FF9900", name: "AWS",         tip: "Cloud infrastructure — EC2, RDS, SSM, and enough IAM policies to fill a small novel."            },
      { icon: "devicon-terraform-plain",                   accent: "#844FBA", name: "Terraform",   tip: "Infrastructure-as-code for cloud provisioning — clicking through the AWS console is not a plan." },
    ].each do |t| %>
      <span class="skill-tag" style="--chip-c: <%= t[:accent] %>" data-tip="<%= t[:tip] %>">
        <i class="<%= t[:icon] %>"></i><%= t[:name] %>
      </span>
    <% end %>
  </div>

  <%# ── Tags ── %>
  <h2 class="mb-4">Tags</h2>
  <div class="tags mb-6">
    <span class="tag">Ruby on Rails</span>
    <span class="tag">Go</span>
    <span class="tag">PostgreSQL</span>
    <span class="tag">Docker</span>
    <span class="tag">Terraform</span>
    <span class="tag">AWS</span>
  </div>

  <%# ── Form elements ── %>
  <h2 class="mb-4">Form Elements</h2>
  <div class="mb-6">
    <div class="field">
      <label class="label">Name</label>
      <div class="control">
        <input class="input" type="text" placeholder="Your name">
      </div>
    </div>
    <div class="field">
      <label class="label">Message</label>
      <div class="control">
        <textarea class="textarea" placeholder="Your message" rows="4"></textarea>
      </div>
    </div>
    <div class="field">
      <div class="control">
        <button class="btn btn-primary">Submit</button>
      </div>
    </div>
  </div>

  <%# ── Form validation ── %>
  <h2 class="mb-4">Form Validation</h2>
  <div class="mb-6">
    <div class="field">
      <label class="label">Email (error state)</label>
      <div class="control">
        <input class="input input-error" type="email" value="not-an-email" placeholder="you@example.com">
      </div>
      <p class="field-error">Please enter a valid email address.</p>
    </div>
    <div class="field">
      <label class="label">Name (valid state)</label>
      <div class="control">
        <input class="input" type="text" placeholder="Your name">
      </div>
    </div>
  </div>

  <%# ── Language Cards ── %>
  <h2 class="mb-4">Language Cards</h2>
  <div class="lang-card-grid mb-6">
    <% @lang_experiences.each do |exp| %>
      <% primary = exp.skills.find { |s| s.icon&.start_with?("devicon") && s.accent.present? } %>
      <% next unless primary %>
      <div class="lang-card" style="--card-accent: <%= primary.accent %>">
        <i class="lang-card-icon <%= primary.icon %>"></i>
        <div class="lang-card-name"><%= exp.name %></div>
        <div class="lang-card-meta"><%= primary.level.capitalize %> · <%= exp.years_of_experience %> yr</div>
        <p class="lang-card-desc"><%= exp.description.strip %></p>
        <div class="lang-card-tags">
          <% exp.skills.each do |s| %>
            <span class="lang-card-tag"><%= s.name %></span>
          <% end %>
        </div>
      </div>
    <% end %>
    <div class="lang-card" style="--card-accent: #3776AB">
      <i class="lang-card-icon devicon-python-plain"></i>
      <div class="lang-card-name">Python</div>
      <div class="lang-card-meta">Familiar</div>
      <p class="lang-card-desc">Scripting, automation, and the occasional data wrangling task.</p>
      <div class="lang-card-tags">
        <span class="lang-card-tag">Scripting</span>
        <span class="lang-card-tag">Automation</span>
      </div>
    </div>
  </div>


</section>
