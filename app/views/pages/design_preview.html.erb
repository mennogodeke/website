<%# ============================================================ %>
<%# DESIGN PREVIEW — component showcase for the design system   %>
<%# ============================================================ %>

<%# ── Preview helper styles ── %>
<style>
  .preview-section { border-top: 1px solid rgba(255,255,255,0.08); }
  .preview-label {
    font-family: var(--app-font-body);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.25);
    margin-bottom: 1.5rem;
  }
  .preview-row {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    gap: 2rem;
    margin-bottom: 2.5rem;
  }
</style>

<%# ============================================================ %>
<%# 1. TITLES                                                    %>
<%# ============================================================ %>
<section class="section is-medium preview-section">
  <div class="title-row">
    <h1 class="title is-1">Titles</h1>
    <div class="subtitle">Typography</div>
  </div>

  <div class="preview-label">Title sizes (is-1 → is-6)</div>
  <h2 class="title is-1">Is-1 — Page Hero</h2>
  <h2 class="title is-2">Is-2 — Section Heading</h2>
  <h2 class="title is-3">Is-3 — Subsection</h2>
  <h2 class="title is-4">Is-4 — Card Heading</h2>
  <h2 class="title is-5">Is-5 — Minor Heading</h2>
  <h2 class="title is-6">Is-6 — Label Heading</h2>

  <div class="preview-label">Subtitle sizes (is-1 → is-6)</div>
  <div class="preview-row" style="align-items: center; flex-wrap: wrap;">
    <div class="subtitle is-1">Is-1</div>
    <div class="subtitle is-2">Is-2</div>
    <div class="subtitle is-3">Is-3 (default)</div>
    <div class="subtitle is-4">Is-4</div>
    <div class="subtitle is-5">Is-5</div>
    <div class="subtitle is-6">Is-6</div>
  </div>

  <div class="preview-label">Title + subtitle paired</div>
  <div class="title-row">
    <h2 class="title is-1">Career</h2>
    <div class="subtitle is-3">Where I've been</div>
  </div>
  <div class="title-row">
    <h2 class="title is-2">Experience</h2>
    <div class="subtitle is-4">What I've been doing</div>
  </div>
  <div class="title-row">
    <h2 class="title is-3">Skills</h2>
    <div class="subtitle is-5">What I'm working with</div>
  </div>
</section>

<%# ============================================================ %>
<%# 2. BUTTONS                                                   %>
<%# ============================================================ %>
<section class="section preview-section">
  <div class="title-row">
    <h2 class="title is-2">Buttons</h2>
    <div class="subtitle">Actions</div>
  </div>

  <div class="preview-label">Variants</div>
  <div class="preview-row">
    <a class="button is-primary">Primary</a>
    <a class="button is-primary">
      View Work <i class="fa-solid fa-arrow-right"></i>
    </a>
    <a class="button is-outlined">Outlined</a>
    <a class="button is-outlined">Download CV</a>
  </div>

  <div class="preview-label">Sizes</div>
  <div class="preview-row">
    <a class="button is-primary is-small">Small</a>
    <a class="button is-primary">Default</a>
    <a class="button is-primary is-medium">Medium</a>
    <a class="button is-primary is-large">Large</a>
  </div>
</section>

<%# ============================================================ %>
<%# 3. JOBS                                                      %>
<%# ============================================================ %>
<section class="section preview-section">
  <div class="title-row">
    <h2 class="title is-2">Jobs</h2>
    <div class="subtitle">Career entries</div>
  </div>

  <div class="career-list">
    <div class="box job-box">
      <div>
        <p class="job-title">Senior Backend Engineer</p>
        <span class="job-company">Acme Corporation</span>
      </div>
      <span class="job-dates">Jan 2022 – Present</span>
    </div>
    <div class="box job-box">
      <div>
        <p class="job-title">Backend Engineer</p>
        <span class="job-company">Globex Industries</span>
      </div>
      <span class="job-dates">Mar 2019 – Dec 2021</span>
    </div>
    <div class="box job-box">
      <div>
        <p class="job-title">Junior Developer</p>
        <span class="job-company">Initech Bureau</span>
      </div>
      <span class="job-dates">Jun 2016 – Feb 2019</span>
    </div>
  </div>
</section>

<%# ============================================================ %>
<%# 4. EXPERTISES                                                %>
<%# ============================================================ %>
<section class="section preview-section">
  <div class="title-row">
    <h2 class="title is-2">Expertises</h2>
    <div class="subtitle">Skill areas</div>
  </div>

  <%
    expertise_sample = [
      { years: "10+", name: "Back-end Development",  desc: "Building robust, scalable server-side systems with a focus on reliability and developer experience. API design, background job processing, database architecture, and performance tuning at scale.", tags: ["Ruby on Rails","PostgreSQL","Redis","Sidekiq"], css: "" },
      { years: "6+",  name: "Cloud & DevOps",        desc: "Infrastructure as code, container orchestration, and CI/CD pipelines. Designing cloud-native systems that scale without surprises, with a strong emphasis on observability and cost efficiency.", tags: ["AWS","Docker","Terraform","GitHub Actions"], css: "" },
      { years: "4+",  name: "iOS & macOS",            desc: "Native Apple platform applications built with Swift and modern frameworks. From App Store shipping to enterprise tooling, with attention to platform conventions and smooth animations.", tags: ["Swift","SwiftUI","Xcode","Combine"], css: "" },
      { years: "5+",  name: "Front-end Development", desc: "Interactive, fast user interfaces built with modern JavaScript and Hotwire. Bridging the gap between server-rendered views and reactive experiences without a full SPA overhead.", tags: ["Hotwire","React","TypeScript","CSS"], css: "" },
    ]
  %>

  <div class="preview-label">Variant A — Number dominant (hover)</div>
  <div class="expertise-grid is-stat" style="margin-bottom: 3rem">
    <% expertise_sample.each do |e| %>
      <div class="expertise-card <%= e[:css] %>">
        <span class="expertise-card-years"><%= e[:years] %></span>
        <h3 class="expertise-card-name"><%= e[:name] %></h3>
        <p class="expertise-card-description"><%= e[:desc] %></p>
        <div class="expertise-card-tags">
          <% e[:tags].each do |t| %><span class="tag skill-tag"><%= t %></span><% end %>
        </div>
      </div>
    <% end %>
  </div>

  <div class="preview-label">Variant B — Image + centered years, rounded (hover)</div>
  <div class="expertise-grid is-band" style="margin-bottom: 3rem">
    <% expertise_sample.each do |e| %>
      <div class="expertise-card <%= e[:css] %>">
        <div class="expertise-card-image-wrap">
          <img src="https://placehold.co/600x338/ffffff/cccccc" alt="">
          <span class="expertise-card-years"><%= e[:years] %></span>
        </div>
        <div class="expertise-card-body">
          <h3 class="expertise-card-name"><%= e[:name] %></h3>
          <p class="expertise-card-description"><%= e[:desc] %></p>
          <div class="expertise-card-tags">
            <% e[:tags].each do |t| %><span class="tag skill-tag"><%= t %></span><% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <div class="preview-label">Variant C — Image + years badge top-right, top border (hover)</div>
  <div class="expertise-grid is-top" style="margin-bottom: 3rem">
    <% expertise_sample.each do |e| %>
      <div class="expertise-card <%= e[:css] %>">
        <div class="expertise-card-image-wrap">
          <img src="https://placehold.co/600x338/ffffff/cccccc" alt="">
        </div>
        <div class="expertise-card-body">
          <div class="expertise-card-header">
            <h3 class="expertise-card-name"><%= e[:name] %></h3>
            <span class="expertise-card-years"><%= e[:years] %></span>
          </div>
          <p class="expertise-card-description"><%= e[:desc] %></p>
          <div class="expertise-card-tags">
            <% e[:tags].each do |t| %><span class="tag skill-tag"><%= t %></span><% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <div class="preview-label">Variant D — Horizontal rows (hover)</div>
  <div class="expertise-grid is-list" style="margin-bottom: 3rem">
    <% expertise_sample.each do |e| %>
      <div class="expertise-card <%= e[:css] %>">
        <span class="expertise-card-years"><%= e[:years] %></span>
        <h3 class="expertise-card-name"><%= e[:name] %></h3>
        <p class="expertise-card-description"><%= e[:desc] %></p>
        <div class="expertise-card-tags">
          <% e[:tags].each do |t| %><span class="tag skill-tag"><%= t %></span><% end %>
        </div>
      </div>
    <% end %>
  </div>

  <div class="preview-label">Default (current)</div>
  <div class="expertise-grid">
    <div class="expertise-card is-featured is-backend">
      <span class="expertise-card-years">10+</span>
      <h3 class="expertise-card-name">Back-end Development</h3>
      <p class="expertise-card-description">Building robust, scalable server-side systems. API design, background jobs, and database architecture.</p>
      <div class="expertise-card-tags">
        <span class="tag skill-tag">Ruby on Rails</span>
        <span class="tag skill-tag">PostgreSQL</span>
        <span class="tag skill-tag">Redis</span>
        <span class="tag skill-tag">Sidekiq</span>
      </div>
    </div>
    <div class="expertise-card is-cloud">
      <span class="expertise-card-years">6+</span>
      <h3 class="expertise-card-name">Cloud & DevOps</h3>
      <p class="expertise-card-description">Infrastructure as code, container orchestration, and CI/CD pipelines.</p>
      <div class="expertise-card-tags">
        <span class="tag skill-tag">AWS</span>
        <span class="tag skill-tag">Docker</span>
        <span class="tag skill-tag">Terraform</span>
      </div>
    </div>
    <div class="expertise-card is-ios">
      <span class="expertise-card-years">4+</span>
      <h3 class="expertise-card-name">iOS & macOS Development</h3>
      <p class="expertise-card-description">Native Apple platform apps with Swift and modern frameworks.</p>
      <div class="expertise-card-tags">
        <span class="tag skill-tag">Swift</span>
        <span class="tag skill-tag">SwiftUI</span>
        <span class="tag skill-tag">Xcode</span>
      </div>
    </div>
    <div class="expertise-card is-frontend">
      <span class="expertise-card-years">5+</span>
      <h3 class="expertise-card-name">Front-end Development</h3>
      <p class="expertise-card-description">Interactive UIs with modern JavaScript and Hotwire.</p>
      <div class="expertise-card-tags">
        <span class="tag skill-tag">Hotwire</span>
        <span class="tag skill-tag">React</span>
        <span class="tag skill-tag">TypeScript</span>
      </div>
    </div>
  </div>
</section>

<%# ============================================================ %>
<%# 5. SKILLS                                                    %>
<%# ============================================================ %>
<section class="section preview-section">
  <div class="title-row">
    <h2 class="title is-2">Skills</h2>
    <div class="subtitle">Individual tools</div>
  </div>

  <div class="preview-label">Grid (hover to reveal level)</div>
  <%
    preview_skills = [
      { name: "Ruby on Rails", level: "expert"     },
      { name: "PostgreSQL",    level: "expert"     },
      { name: "Sidekiq",       level: "expert"     },
      { name: "RSpec",         level: "expert"     },
      { name: "Docker",        level: "proficient" },
      { name: "AWS",           level: "proficient" },
      { name: "Redis",         level: "proficient" },
      { name: "GraphQL",       level: "proficient" },
      { name: "React",         level: "familiar"   },
      { name: "Swift",         level: "familiar"   },
      { name: "Kubernetes",    level: "familiar"   },
      { name: "Terraform",     level: "familiar"   },
    ]
  %>
  <div class="skills-grid">
    <% preview_skills.each do |skill| %>
      <div class="card skill-card">
        <div class="card-content skill-card-footer">
          <p class="skill-card-name"><%= skill[:name] %></p>
        </div>
        <div class="skill-card-image-wrap">
          <figure class="image is-square">
            <img src="https://placehold.co/256x256" alt="<%= skill[:name] %>">
          </figure>
          <div class="skill-card-level is-<%= skill[:level] %>">
            <span class="skill-level-badge is-<%= skill[:level] %>"><%= skill[:level].upcase %></span>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</section>

<%# ============================================================ %>
<%# 6. PROJECTS                                                  %>
<%# ============================================================ %>
<section class="section preview-section">
  <div class="title-row">
    <h2 class="title is-2">Projects</h2>
    <div class="subtitle">Work</div>
  </div>
</section>
