<section class="section">
  <div class="container">

    <%# Header %>
    <div class="level">
      <div class="level-left">
        <div class="level-item">
          <div>
            <h1 class="title is-1">Menno Godeke</h1>
            <p class="subtitle">Full-stack Software Engineer</p>
          </div>
        </div>
      </div>
      <div class="level-right">
        <div class="level-item">
          <div class="box has-text-centered has-text-weight-bold">MG</div>
        </div>
      </div>
    </div>

    <%# Two-column body %>
    <div class="columns">

      <%# Left column: About + Skills + Languages %>
      <aside class="column is-one-quarter">

        <section>
          <h2 class="title is-2">About</h2>
          <p class="content"><%= t 'pages.home.intro' %></p>
        </section>

        <section>
          <h2 class="title is-2">Skills</h2>
          <% @skills.group_by(&:level).sort_by { |level, _| -Skill.levels[level] }.each do |level, skills| %>
            <div>
              <span class="label"><%= level.capitalize %></span>
              <div class="tags">
                <% skills.each do |skill| %>
                  <span class="tag"><%= skill.name %></span>
                <% end %>
              </div>
            </div>
          <% end %>
        </section>

        <section>
          <h2 class="title is-2">Languages</h2>
          <ul>
            <li><strong>Dutch</strong> — Native</li>
            <li><strong>English</strong> — Fluent</li>
            <li><strong>German</strong> — Fluent</li>
          </ul>
        </section>

      </aside>

      <%# Right column: Experience %>
      <main class="column">

        <section>
          <h2 class="title is-2">Experience</h2>

          <% @jobs.each do |job| %>
            <article class="block">
              <div class="level">
                <div class="level-left">
                  <div class="level-item">
                    <div>
                      <p class="title is-5"><%= job.title %></p>
                      <p class="subtitle is-6"><%= job.company %></p>
                    </div>
                  </div>
                </div>
                <div class="level-right">
                  <span class="tag">
                    <%= job.start_date.strftime("%b %Y") %> – <%= job.end_date ? job.end_date.strftime("%b %Y") : "Present" %>
                  </span>
                </div>
              </div>
              <% if job.description.present? %>
                <p class="content"><%= job.description %></p>
              <% end %>
              <% if job.skills.any? %>
                <div class="tags">
                  <% job.skills.each do |skill| %>
                    <span class="tag"><%= skill.name %></span>
                  <% end %>
                </div>
              <% end %>
            </article>
          <% end %>

        </section>

      </main>

    </div>

  </div>
</section>
