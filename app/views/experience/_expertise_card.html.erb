<% card_class = case expertise_card.name
    when /back.?end/i    then "is-backend"
    when /cloud|devops/i then "is-cloud"
    when /ios|macos/i    then "is-ios"
    when /front.?end/i   then "is-frontend"
    else ""
    end %>
<div class="expertise-card <%= card_class %>">
  <div class="expertise-card-image-wrap">
    <img src="https://placehold.co/600x338/ffffff/cccccc" alt="">
  </div>
  <div class="expertise-card-body">
    <div class="expertise-card-header">
      <h2 class="expertise-card-name"><%= expertise_card.name %></h2>
      <span class="expertise-card-years"><%= expertise_card.years_of_experience %>+</span>
    </div>
    <p class="expertise-card-description"><%= expertise_card.description %></p>
    <div class="expertise-card-tags">
      <% expertise_card.skills.each do |skill| %>
        <span class="tag skill-tag"><%= skill.name %></span>
      <% end %>
    </div>
  </div>
</div>
