<section class="section container" data-controller="experience">

  <h1><%= t 'pages.experience.title' %></h1>
  <div class="exp-row">
    <%# Rail %>
    <div class="exp-rail" role="tablist">
      <% @experiences.each_with_index do |experience, i| %>
        <button
          class="row<%= i == 0 ? " active" : "" %>"
          role="tab"
          aria-selected="<%= i == 0 %>"
          data-experience-target="row"
          data-experience-key="<%= experience.category %>"
          data-action="click->experience#select"
          style="--row-color: var(--color-<%= experience.accent %>)"
        >
          <span class="rank"><%= "%02d" % (i + 1) %></span>
          <div class="label-col">
            <span class="name"><%= experience.name %></span>
          </div>
          <span class="chevron">›</span>
        </button>
      <% end %>
    </div>

    <%# Panels %>
    <div>
      <% @experiences.each_with_index do |experience, i| %>
        <% primary = experience.experience_skills.select(&:primary?).map(&:skill) %>
        <% secondary = experience.experience_skills.reject(&:primary?).map(&:skill) %>
        <% panel_grad = "linear-gradient(160deg, var(--highlight-#{experience.accent}-from) 0%, var(--highlight-#{experience.accent}-mid) 50%, var(--highlight-#{experience.accent}-to) 100%)" %>
        <div
          class="exp-panel"
          data-experience-target="panel"
          data-experience-key="<%= experience.category %>"
          style="--panel-color: var(--color-<%= experience.accent %>); --panel-grad: <%= panel_grad %>"
          <%= i == 0 ? "" : "hidden" %>
        >
          <div class="exp-panel-header">
            <h2><span class="exp-title-stroke"><%= experience.name.upcase %></span></h2>
          </div>

          <p class="exp-panel-desc">
            <strong><%= experience.years_of_experience %> years of experience</strong> — <%= experience.description %>
          </p>

          <% if primary.any? %>
            <div class="exp-skills-header">
              <span>Top <%= primary.count %> · primary</span>
            </div>
            <div class="sk-primary">
              <% primary.each do |skill| %>
                <div class="sk-card" style="--chip-c: <%= skill.accent.present? ? skill.accent : "var(--color-text-faint)" %>">
                  <i class="<%= skill.icon %> icon"></i>
                  <span class="name"><%= skill.name %></span>
                  <p class="desc"><%= skill.description.strip %></p>
                </div>
              <% end %>
            </div>
          <% end %>

          <% if secondary.any? %>
            <div class="exp-skills-header">
              <span>Also used</span>
            </div>
            <div class="sk-secondary">
              <% secondary.each do |skill| %>
                <% chip_c = skill.accent.present? ? skill.accent : "var(--color-text-faint)" %>
                <span class="sk-chip" style="--chip-c: <%= chip_c %>" data-tooltip="<%= skill.description.strip %>">
                  <i class="<%= skill.icon %>"></i><%= skill.name %>
                </span>
              <% end %>
            </div>
          <% end %>

        </div>
      <% end %>
    </div>

  </div>
</section>
