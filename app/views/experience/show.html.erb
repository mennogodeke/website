<section class="section is-medium container is-max-widescreen" data-controller="experience">

  <h1 class="title is-1"><%= t 'pages.experience.title' %></h1>
  <h2 class="title is-2"><%= t 'pages.experience.subtitle' %></h2>

  <%# Two-column layout: 320px rail + flexible panel %>
  <div class="exp-row">

    <%# Rail %>
    <div class="exp-rail" role="tablist">
      <% @expertises.each do |expertise| %>
        <button
          class="row"
          role="tab"
          aria-selected="false"
          data-experience-target="row"
          data-experience-key="<%= expertise.category %>"
          data-action="click->experience#select"
          style="--row-color: var(--bulma-<%= expertise.accent %>)"
        >
          <span><%= expertise.name %></span>
          <span class="yr"><%= expertise.years_of_experience %>YR</span>
          <span class="chevron">›</span>
        </button>
      <% end %>
    </div>

    <%# Panels %>
    <div>
      <% @expertises.each do |expertise| %>
        <% sorted_skills = expertise.skills.sort_by { |s| -Skill.levels[s.level] } %>
        <div
          class="exp-panel"
          data-experience-target="panel"
          data-experience-key="<%= expertise.category %>"
          style="--panel-color: var(--bulma-<%= expertise.accent %>)"
          hidden
        >
          <%# Header: area name + years count %>
          <div class="is-flex is-align-items-baseline is-justify-content-space-between is-flex-wrap-wrap mb-4">
            <h2 class="title is-2 mb-0"><%= expertise.name.upcase %></h2>
            <div class="is-flex is-align-items-baseline">
              <span class="exp-years-num mr-2"><%= expertise.years_of_experience %></span>
              <span class="is-family-code is-size-7">YEARS</span>
            </div>
          </div>

          <%# Description %>
          <p class="is-size-5 mb-5"><%= expertise.description %></p>

          <%# Skills header %>
          <div class="is-flex is-align-items-baseline is-justify-content-space-between mb-3">
            <span class="is-family-code is-size-7">Skills · ordered by proficiency</span>
            <span class="is-family-code is-size-7"><%= expertise.skills.count %> total</span>
          </div>

          <%# Skill rows %>
          <div>
            <% sorted_skills.each_with_index do |skill, i| %>
              <% pct = skill.expert? ? 100 : skill.proficient? ? 66 : 33 %>
              <div class="sk-row">
                <span class="is-size-7 has-text-weight-bold is-uppercase"><%= skill.name %></span>
                <div class="bar">
                  <i data-width="<%= pct %>" style="transition-delay: <%= i * 30 %>ms"></i>
                </div>
                <span class="is-family-code is-size-7 has-text-right"><%= skill.level.capitalize %></span>
              </div>
            <% end %>
          </div>

        </div>
      <% end %>
    </div>

  </div>
</section>
