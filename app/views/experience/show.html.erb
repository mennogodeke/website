<%# ============================================================ %>
<%# 1. EXPERTISE — feature cards grid %>
<%# ============================================================ %>
<section class="section is-medium container is-max-widescreen">
  <h1 class="title is-1"><%= t 'pages.experience.title' %></h1>
  <h2 class="title is-2"><%= t 'pages.experience.subtitle' %></h2>

  <div class="expertise-grid is-top">
    <%= render partial: "experience/expertise_card", collection: @expertises, as: :expertise_card %>
  </div>
</section>

<%# ============================================================ %>
<%# 2. SKILLS — 6-column card grid %>
<%# ============================================================ %>
<section class="section container is-max-widescreen">
  <h2 class="title is-2">What I'm working with</h2>

  <div class="skills-grid">
    <% skills_to_show = [
      { name: "Ruby on Rails", level: "expert" },
      { name: "PostgreSQL",    level: "expert" },
      { name: "Docker",        level: "proficient" },
      { name: "AWS",           level: "proficient" },
      { name: "React",         level: "familiar" },
      { name: "Swift",         level: "familiar" },
      { name: "Kubernetes",    level: "familiar" },
      { name: "Redis",         level: "proficient" },
      { name: "GraphQL",       level: "proficient" },
      { name: "Terraform",     level: "familiar" },
      { name: "Sidekiq",       level: "expert" },
      { name: "RSpec",         level: "expert" },
      { name: "Linux",         level: "expert" },
      { name: "Git",           level: "expert" },
      { name: "JavaScript",    level: "proficient" },
      { name: "TypeScript",    level: "proficient" },
      { name: "Python",        level: "proficient" },
      { name: "Nginx",         level: "proficient" },
      { name: "Kamal",         level: "proficient" },
      { name: "Hotwire",       level: "proficient" },
      { name: "Stimulus",      level: "proficient" },
      { name: "Ansible",       level: "familiar" },
      { name: "Elasticsearch", level: "familiar" },
      { name: "Kafka",         level: "familiar" },
      { name: "MySQL",         level: "familiar" },
      { name: "Vue.js",        level: "familiar" },
      { name: "iOS",           level: "proficient" },
      { name: "CI/CD",         level: "proficient" },
      { name: "macOS",         level: "familiar" },
      { name: "Turbo",         level: "proficient" }
    ] %>

    <% skills_to_show.each do |skill| %>
      <% name = skill.respond_to?(:name) ? skill.name : skill[:name] %>
      <figure class="image is-128x128 skill-badge">
        <img src="https://placehold.co/256x256/ffffff/cccccc" alt="<%= name %>">
        <span class="skill-badge-name"><%= name %></span>
      </figure>
    <% end %>
  </div>
</section>
