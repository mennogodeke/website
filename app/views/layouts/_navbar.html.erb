<div data-controller="navbar">
  <nav class="navbar" role="navigation" aria-label="main navigation">
    <div class="navbar-inner">
      <%= link_to root_path, class: "navbar-logo", aria: { label: "MENNO.CODES – home" } do %>
        <%= image_tag "logo/menno-codes-stacked-dark.svg",  class: "navbar-logo-img navbar-logo-dark",  alt: "" %>
        <%= image_tag "logo/menno-codes-stacked-light.svg", class: "navbar-logo-img navbar-logo-light", alt: "" %>
      <% end %>

      <ul class="navbar-links">
        <li><%= link_to t("nav.home"),       root_path,       class: "navbar-link #{'is-active' if current_page?(root_path)}" %></li>
        <li><%= link_to t("nav.career"),     jobs_path,       class: "navbar-link #{'is-active' if current_page?(jobs_path)}" %></li>
        <li><%= link_to t("nav.experience"), experience_path, class: "navbar-link #{'is-active' if current_page?(experience_path)}" %></li>
        <li><%= link_to t("nav.projects"),   projects_path,   class: "navbar-link #{'is-active' if current_page?(projects_path)}" %></li>
        <li><%= link_to t("nav.contact"),    contact_path,    class: "navbar-link #{'is-active' if current_page?(contact_path)}" %></li>
      </ul>

      <div class="navbar-ctas">
        <%= button_to theme_path,
              method: :post,
              params: { theme: current_theme == "dark" ? "light" : "dark" },
              class: "theme-toggle",
              form: { data: { turbo: false } },
              aria: { label: "Switch to #{current_theme == 'dark' ? 'light' : 'dark'} theme" } do %>
          <i class="fa-solid <%= current_theme == 'dark' ? 'fa-sun' : 'fa-moon' %>"></i>
        <% end %>
        <span class="navbar-cta-divider">|</span>
        <%= render "layouts/locale_switcher" %>
      </div>

      <button class="navbar-burger" aria-label="menu" aria-expanded="false"
              data-navbar-target="burger"
              data-action="click->navbar#toggle">
        <span aria-hidden="true"></span>
        <span aria-hidden="true"></span>
        <span aria-hidden="true"></span>
      </button>
    </div>
  </nav>

  <div class="navbar-menu" data-navbar-target="menu">
    <ul class="navbar-links">
      <li><%= link_to t("nav.home"),       root_path,       class: "navbar-link #{'is-active' if current_page?(root_path)}" %></li>
      <li><%= link_to t("nav.career"),     jobs_path,       class: "navbar-link #{'is-active' if current_page?(jobs_path)}" %></li>
      <li><%= link_to t("nav.experience"), experience_path, class: "navbar-link #{'is-active' if current_page?(experience_path)}" %></li>
      <li><%= link_to t("nav.projects"),   projects_path,   class: "navbar-link #{'is-active' if current_page?(projects_path)}" %></li>
      <li><%= link_to t("nav.contact"),    contact_path,    class: "navbar-link #{'is-active' if current_page?(contact_path)}" %></li>
    </ul>
  </div>
</div>
