#!/usr/bin/env bash
# Symlinks committed hooks into .git/hooks/. Run once after cloning.
set -euo pipefail

HOOKS_DIR="$(git rev-parse --show-toplevel)/hooks"
GIT_HOOKS_DIR="$(git rev-parse --git-dir)/hooks"

for hook in "$HOOKS_DIR"/*; do
  name=$(basename "$hook")
  target="$GIT_HOOKS_DIR/$name"

  ln -sf "$hook" "$target"
  chmod +x "$hook"
  echo "Installed: $name"
done

echo "Done. Git hooks are active."
