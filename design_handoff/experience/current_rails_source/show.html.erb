<section class="section container" data-controller="experience">

  <h1><%= t 'pages.experience.title' %></h1>
  <h2><%= t 'pages.experience.subtitle' %></h2>

  <div class="exp-row">

    <%# Rail %>
    <div class="exp-rail" role="tablist">
      <% @experiences.each do |experience| %>
        <button
          class="row"
          role="tab"
          aria-selected="false"
          data-experience-target="row"
          data-experience-key="<%= experience.category %>"
          data-action="click->experience#select"
          style="--row-color: var(--color-<%= experience.accent %>)"
        >
          <i class="<%= experience_rail_icon(experience.category) %> row-icon"></i>
          <span><%= experience.name %></span>
          <span class="yr"><%= experience.years_of_experience %>YR</span>
          <span class="chevron">›</span>
        </button>
      <% end %>
    </div>

    <%# Panels %>
    <div>
      <% @experiences.each do |experience| %>
        <% sorted_skills = experience.skills.sort_by { |s| -Skill.levels[s.level] } %>
        <div
          class="exp-panel"
          data-experience-target="panel"
          data-experience-key="<%= experience.category %>"
          style="--panel-color: var(--color-<%= experience.accent %>)"
          hidden
        >
          <div class="exp-panel-header mb-4">
            <h2><%= experience.name.upcase %></h2>
            <div class="exp-panel-years">
              <span class="exp-years-num"><%= experience.years_of_experience %></span>
              <span class="text-xs">YEARS</span>
            </div>
          </div>

          <p class="mb-5"><%= experience.description %></p>

          <div class="exp-skills-header mb-3">
            <span class="text-xs">Skills · ordered by proficiency</span>
            <span class="text-xs"><%= experience.skills.count %> total</span>
          </div>

          <div>
            <% sorted_skills.each_with_index do |skill, i| %>
              <% pct = skill.expert? ? 100 : skill.proficient? ? 66 : 33 %>
              <div class="sk-row">
                <span class="sk-name"><%= skill.name %></span>
                <div class="bar">
                  <i data-width="<%= pct %>" style="transition-delay: <%= i * 30 %>ms"></i>
                </div>
                <span class="text-xs sk-level"><%= skill.level.capitalize %></span>
              </div>
            <% end %>
          </div>

        </div>
      <% end %>
    </div>

  </div>
</section>
